{
  "expo": {
    "name": "NONETPAY",
    "slug": "offline-pay",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "offlinepay",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "platforms": ["ios", "android", "web"],
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a8a"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/011c1998-23a4-4110-8332-7785c719ff27"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "android": {
      "package": "com.ashlesh.offlinepay",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#1e3a8a"
      },
      "permissions": [
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NONETPAY to access your camera to scan QR codes."
        }
      ],
      "expo-secure-store",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow NONETPAY to save receipts to your Downloads folder.",
          "savePhotosPermission": "Allow NONETPAY to save receipt PDFs.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-foreground.png",
          "color": "#16a34a",
          "defaultChannel": "offline-pay"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "011c1998-23a4-4110-8332-7785c719ff27"
      }
    },
    "owner": "ashleshs"
  }
}
